# Vivarium configuration — copy to `.env` and fill in for your host.
# `.env` is gitignored; never commit real values.

# --- core (required) ---
# Host filesystem path that holds per-session workspaces. The Docker daemon
# resolves session bind-mounts against the HOST fs, so this must be a real path
# on the host (not a path inside the container).
HOST_WORK_ROOT=/srv/vivarium/work
# Mount point of HOST_WORK_ROOT inside the orchestrator container.
LOCAL_WORK_ROOT=/work
# Where the session list is persisted (inside the container).
CCCHAT_STATE=/state/sessions.json
# Docker image each session runs (a Claude Code CLI image; see docs).
SESSION_IMAGE=claude-term:local
# Required by the Claude Code CLI to run non-interactively as root in a sandbox.
IS_SANDBOX=1

# --- optional integrations (leave blank to disable) ---
# SSH host the user's local VS Code Remote-SSH should connect to; the UI builds
# vscode://vscode-remote/ssh-remote+<host>/<workspace>. Blank hides the button.
VSCODE_SSH_HOST=
# External whisper-stt endpoint for voice input; blank falls back to the browser
# Web Speech API. Example: http://localhost:9100
STT_UPSTREAM=
# Extra admin usernames (comma-separated). The username "admin" is always admin.
CCCHAT_ADMINS=

# --- optional credential mounts (admin-only, host paths) ---
# Host paths exposed as opt-in, admin-only session mounts. Leave blank if unused.
HOST_SSH=
HOST_MACHINES=

# --- auth ---
# Initial admin password (first boot only). If unset, a random one is generated
# and printed to the logs. There is never a default admin/admin.
CCCHAT_ADMIN_PASSWORD=
# Secret for signing auth cookies. If unset, a random secret is generated and
# persisted next to the users file. Set explicitly to share across instances.
CCCHAT_AUTH_SECRET=
# Cookie lifetime in days (default 14).
CCCHAT_AUTH_TTL_DAYS=
# Set to 0 to disable the app's auth layer (only if a trusted outer gate handles it).
CCCHAT_REQUIRE_AUTH=

# --- email (optional: password recovery + verification, via Resend) ---
# Leave RESEND_API_KEY blank to disable all email (recovery links won't be sent).
RESEND_API_KEY=
RESEND_FROM=
# Public base URL used to build reset/verify links, e.g. https://vivarium.example.com
CCCHAT_BASE_URL=

# --- web push notifications (optional) ---
# Contact for the VAPID claim — MUST be a routable mailto:/https: (Apple rejects
# non-real domains). Example: mailto:admin@example.com
CCCHAT_VAPID_SUB=

# --- idle session reaper (optional) ---
# Stop containers idle for this many hours (0/blank = disabled). Admin-tunable in the UI.
CCCHAT_IDLE_REAP_HOURS=

# --- Cloudflare Access (optional outer SSO gate) ---
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
